<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Einkaufsliste.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Einkaufsliste"
    Title="Einkaufsliste"
    FlyoutBehavior="Flyout">

    <Shell.FlyoutHeader>
        <Grid Padding="16" BackgroundColor="{AppThemeBinding Light=#F2F2F2, Dark=#222}">
            <VerticalStackLayout>
                <Label Text="Einkaufsliste" FontAttributes="Bold" FontSize="24" />
                <Label Text="Schnell &amp; einfach" Opacity="0.7" FontSize="12" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Liste" Route="home">
        <ShellContent Title="Einkaufsliste" ContentTemplate="{DataTemplate local:MainPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Einstellungen" Route="settings">
        <ShellContent Title="Einstellungen" ContentTemplate="{DataTemplate local:SettingsPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Über" Route="about">
        <ShellContent Title="Über" ContentTemplate="{DataTemplate local:AboutPage}" />
    </FlyoutItem>

</Shell>