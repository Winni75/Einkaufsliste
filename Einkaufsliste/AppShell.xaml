<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Einkaufsliste.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Einkaufsliste"
    Title="Einkaufsliste"
    FlyoutBehavior="Flyout">

    <FlyoutItem Title="Listen" Route="Lists">
        <ShellContent Title="Listen" ContentTemplate="{DataTemplate local:ListsPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Einstellungen" Route="settings">
        <ShellContent Title="Einstellungen" ContentTemplate="{DataTemplate local:SettingsPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Über" Route="about">
        <ShellContent Title="Über" ContentTemplate="{DataTemplate local:AboutPage}" />
    </FlyoutItem>

</Shell>