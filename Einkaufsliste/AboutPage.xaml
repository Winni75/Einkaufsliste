<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Einkaufsliste.AboutPage"
             Title="Über diese App">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="🛒 Einkaufsliste" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" />

            <Label Text="Version 1.1"
                   FontSize="16"
                   Opacity="0.6"
                   HorizontalOptions="Center" />

            <BoxView HeightRequest="1" 
                     BackgroundColor="{AppThemeBinding Light=#CCCCCC, Dark=#444444}" />

            <Label Text="Diese App wurde mit .NET MAUI entwickelt." 
                   FontSize="18" />

            <Label Text="Funktionen:" FontSize="20" FontAttributes="Bold" />
            <Label Text="• Produkte hinzufügen" FontSize="16" />
            <Label Text="• Produkte abhaken (durchstreichen &amp; nach unten sortieren)" FontSize="16" />
            <Label Text="• Erledigte Produkte löschen" FontSize="16" />
            <Label Text="• Mehrere Listen verwalten (z. B. pro Shop)" FontSize="16" />
            <Label Text="• Schriftgröße einstellbar" FontSize="16" />
            <Label Text="• Automatisches Speichern" FontSize="16" />

            <BoxView HeightRequest="1" 
                     BackgroundColor="{AppThemeBinding Light=#CCCCCC, Dark=#444444}" />

            <Label Text="Entwickelt von: Winfried Zeißig" FontSize="16" />
            <Label Text="Kontakt: zeissigw@gmx.de" FontSize="16" />

            <Label Text="Lizenz: MIT" FontSize="14" Opacity="0.6" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>