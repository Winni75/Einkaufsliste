<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Einkaufsliste.Models"
             x:Class="Einkaufsliste.MainPage"
             x:Name="RootPage"
             Title="{Binding Title}">

    <AbsoluteLayout>

        <!-- Scrollbare Liste -->
        <CollectionView ItemsSource="{Binding Items}"
                        SelectionMode="Single"
                        SelectionChanged="Items_SelectionChanged"
                        AbsoluteLayout.LayoutBounds="0,0,1,1"
                        AbsoluteLayout.LayoutFlags="All"
                        Margin="16,8,16,100">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ShoppingItem">
                    <Border Padding="12,10" BackgroundColor="Transparent" StrokeThickness="0">
                        <Label Text="{Binding Name}"
                               FontSize="{DynamicResource ItemFontSize}"
                               VerticalOptions="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsCompleted}"
                                             Value="True">
                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                    <Setter Property="TextColor" Value="Gray"/>
                                    <Setter Property="Opacity" Value="0.6"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <BoxView HeightRequest="96" Opacity="0"/>
            </CollectionView.Footer>
        </CollectionView>

        <!-- Eingabefeld über den Buttons -->
        <Border Padding="8"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#333333}"
                StrokeThickness="1"
                IsVisible="{Binding IsInputVisible}"
                AbsoluteLayout.LayoutBounds="0.5,1,1,AutoSize"
                AbsoluteLayout.LayoutFlags="WidthProportional,PositionProportional"
                Margin="16,0,16,70">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10"/>
            </Border.StrokeShape>

            <Entry x:Name="NewItemEntry"
                   Placeholder="Neuer Artikel"
                   Text="{Binding NewItemName}"
                   ReturnType="Done"
                   Completed="NewItemEntry_Completed"/>
        </Border>

        <!-- Grüner + FAB -->
        <Button Text="+"
                FontSize="28"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                BackgroundColor="Green"
                TextColor="White"
                Command="{Binding ShowInputCommand}"
                Clicked="PlusButton_Clicked"
                AbsoluteLayout.LayoutBounds="1,1,AutoSize,AutoSize"
                AbsoluteLayout.LayoutFlags="PositionProportional"
                Margin="16">
            <Button.Shadow>
                <Shadow Brush="Black"
                        Opacity="0.3"
                        Radius="12"/>
            </Button.Shadow>
        </Button>

        <!-- Roter Löschen-Button -->
        <Button Text="Lösche erledigte"
                FontSize="16"
                BackgroundColor="Red"
                TextColor="White"
                CornerRadius="10"
                Command="{Binding RemoveCompletedCommand}"
                AbsoluteLayout.LayoutBounds="0,1,AutoSize,AutoSize"
                AbsoluteLayout.LayoutFlags="PositionProportional"
                Margin="16,16,0,16">
            <Button.Shadow>
                <Shadow Brush="Black"
                        Opacity="0.3"
                        Radius="12"/>
            </Button.Shadow>
        </Button>
    </AbsoluteLayout>
</ContentPage>