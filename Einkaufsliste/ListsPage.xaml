<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Einkaufsliste.ListsPage"
             x:Name="Root"
             Title="Deine Einkaufslisten">

    <AbsoluteLayout>

        <!-- Listenübersicht -->
        <CollectionView ItemsSource="{Binding Lists}"
                        SelectionMode="None"
                        AbsoluteLayout.LayoutBounds="0,0,1,1"
                        AbsoluteLayout.LayoutFlags="All"
                        Margin="16,16,16,100">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <!-- Karte für jede Liste -->
                    <Frame Padding="14,10"
                           Margin="0,6"
                           HasShadow="True"
                           CornerRadius="12"
                           BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

                        <!-- Tippen auf die Karte -> Liste öffnen -->
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.OpenListCommand, Source={x:Reference Root}}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>

                        <Grid ColumnDefinitions="*,Auto">
                            <!-- Listenname -->
                            <Label Text="{Binding Name}"
                                   FontSize="20"
                                   VerticalOptions="Center"
                                   LineBreakMode="TailTruncation" />

                            <!-- Roter Löschbutton rechts -->
                            <Button Grid.Column="1"
                                    Text="🗑️"
                                    FontSize="16"
                                    WidthRequest="44" HeightRequest="44"
                                    CornerRadius="22"
                                    Padding="0"
                                    BackgroundColor="#D32F2F"
                                    TextColor="White"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"
                                    Command="{Binding BindingContext.DeleteListCommand, Source={x:Reference Root}}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <!-- etwas Abstand nach unten, damit letzter Eintrag nicht unter FAB verschwindet -->
            <CollectionView.Footer>
                <BoxView HeightRequest="80" Opacity="0"/>
            </CollectionView.Footer>
        </CollectionView>

        <!-- Grüner Floating-Button unten rechts -->
        <Button Text="+"
                FontSize="28"
                WidthRequest="60" HeightRequest="60"
                CornerRadius="30"
                BackgroundColor="Green"
                TextColor="White"
                Command="{Binding AddListCommand}"
                AbsoluteLayout.LayoutBounds="1,1,AutoSize,AutoSize"
                AbsoluteLayout.LayoutFlags="PositionProportional"
                Margin="16">
            <Button.Shadow>
                <Shadow Brush="Black" Opacity="0.3" Radius="12"/>
            </Button.Shadow>
        </Button>

    </AbsoluteLayout>
</ContentPage>